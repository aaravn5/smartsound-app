{
  "name": "smartsound-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SmartSound backend scaffold: auth (Google/Apple OAuth), usage metering, Stripe billing. Self-contained — never bundled into the SPA.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "arctic": "^2.3.4",
    "hono": "^4.6.14",
    "oslo": "^1.2.1",
    "stripe": "^17.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
