# Copy to .env and fill in real values. .env is git-ignored (see repo root .gitignore).
# Every key below is read by server/src/env.ts. Routes that need an unset key
# in GOOGLE_*/APPLE_*/STRIPE_* return 503 {error:'not_configured', missing:[...]}
# instead of crashing — the server boots and serves everything else without them.

# --- Core -------------------------------------------------------------------
PORT=8787
# Signs the session cookie (HMAC via Hono's setSignedCookie/getSignedCookie).
# Generate one with: openssl rand -base64 48
SESSION_SECRET=
# Where the SQLite file lives. Relative paths resolve against the server's cwd.
DB_PATH=./data/smartsound.db
# Origin the SPA is served from — used for CORS and for OAuth/Stripe redirect URLs.
PUBLIC_ORIGIN=http://localhost:5173

# --- Google OAuth (Sign in with Google) --------------------------------------
# Create at https://console.cloud.google.com/apis/credentials — OAuth client ID,
# type "Web application". Add GOOGLE_REDIRECT_URI as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# --- Apple OAuth (Sign in with Apple) ----------------------------------------
# Create at https://developer.apple.com/account/resources/identifiers — a
# Services ID (= APPLE_CLIENT_ID) with "Sign in with Apple" enabled, plus a
# private key (.p8) generated for that Service ID (its ID = APPLE_KEY_ID).
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the .p8 file's PEM contents. Either literal newlines (heredoc) or a
# single line with \n escapes both work — server/src/env.ts un-escapes \n.
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8787/api/auth/apple/callback

# --- Stripe billing -----------------------------------------------------------
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# From the webhook endpoint you register (stripe listen --print-secret for local dev)
STRIPE_WEBHOOK_SECRET=
# Price IDs for the four paid SKUs (§4.1) — create Products/Prices in the
# Stripe dashboard or via `stripe products create` / `stripe prices create`.
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_STUDIO_MONTH=
STRIPE_PRICE_STUDIO_YEAR=
